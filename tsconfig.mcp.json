{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist/mcp-server",
    "rootDir": "mcp-server"
  },
  "include": ["mcp-server/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
